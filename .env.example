# Copy this file to .env and fill in values before running docker compose.
# .env is gitignored — never commit real secrets.

# PostgreSQL (local dev substitute for Supabase)
POSTGRES_DB=goalz
POSTGRES_USER=goalz
POSTGRES_PASSWORD=changeme

# Supabase
ConnectionStrings__DefaultConnection="change"

# MinIO object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
JWT_SECRET=changeme-use-a-long-random-string-in-production
