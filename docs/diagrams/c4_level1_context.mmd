flowchart TB
    admin["Admin / Staff<br>Monitors operations and reviews system outputs"] -- Monitors and reviews --> logging["Logging Platform<br>Core system that manages engagement, collects sensor and image data, processes analysis, and provides reporting tools"]
    student["Student<br>Explores routes, captures images, and participates in activities"] -- Uses platform --> logging
    sensor["Sensor / IoT<br>Provides environmental and location data"] -- Sends environmental data --> logging
    logging -- Sends images for analysis --> ai["AI Analysis Service<br>Analyzes images and returns insights"]
    ai -- Returns analysis insights --> logging
    logging -- Requests maps and routes --> mapapi["Map API<br>Provides maps, routes, and geolocation services"]
    mapapi -- Returns map and geolocation data --> logging
    logging -- Stores and retrieves data --> db["Databases<br>Stores user data, sensor data, images, and analysis results"]

     admin:::person
     logging:::system
     student:::person
     sensor:::external
     ai:::external
     mapapi:::external
     db:::external
    classDef person fill:#e3f2fd,stroke:#1e88e5,stroke-width:2px,font-size:14px
    classDef system fill:#e8f5e9,stroke:#43a047,stroke-width:2px,font-size:14px
    classDef external fill:#fff3e0,stroke:#fb8c00,stroke-width:2px,font-size:14px