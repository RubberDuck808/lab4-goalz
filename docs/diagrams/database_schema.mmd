erDiagram
    students {
        UUID id PK
        VARCHAR name
        VARCHAR school
        TIMESTAMP created_at
    }
    routes {
        UUID id PK
        UUID student_id FK
        VARCHAR name
        JSONB coordinates
        TIMESTAMP created_at
    }
    sensor_logs {
        UUID id PK
        UUID route_id FK
        FLOAT temperature
        FLOAT humidity
        FLOAT co2_ppm
        TIMESTAMP recorded_at
    }
    scores {
        UUID id PK
        UUID student_id FK
        UUID route_id FK
        INT points
        TIMESTAMP awarded_at
    }
    photos {
        UUID id PK
        UUID route_id FK
        VARCHAR storage_key
        TIMESTAMP uploaded_at
    }

    students ||--o{ routes : "walks"
    routes ||--o{ sensor_logs : "generates"
    routes ||--o{ scores : "earns"
    routes ||--o{ photos : "has"
